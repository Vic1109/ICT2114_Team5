
{% set threat_emoji = {
    'CRITICAL': '🔴',
    'HIGH': '🟡', 
    'MEDIUM': '🟠',
    'LOW': '🟢'
} %}
{% set threat_color = threat_emoji.get(analysis.threat_level, '⚪') %}

{{ threat_color }} {{ alert_type }} ALERT - {{ analysis.threat_level }} {{ threat_color }}
