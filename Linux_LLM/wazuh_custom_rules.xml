<!-- Custom Suricata rules for SME SOC Framework -->

<group name="custom_suricata,">

<!-- ========== CRITICAL THREATS (Level 14-16) ========== -->

<!-- Data Exfiltration - MITRE T1041 -->
<rule id="100001" level="15">
    <if_sid>86601</if_sid>
    <field name="alert.signature">ET POLICY Large outbound HTTPS response</field>
    <description>CRITICAL: Potential data exfiltration via HTTPS</description>
    <options>no_full_log</options>
</rule>

<!-- Ransomware - MITRE T1486 -->
<rule id="100002" level="16">
