<!-- ========== CORRELATION RULES ========== -->

<!-- Multiple credential attacks -->
<rule id="100050" level="13" frequency="5" timeframe="300">
    <if_matched_sid>100010</if_matched_sid>
    <same_source_ip />
    <description>HIGH: Multiple credential attacks from same source IP</description>
</rule>

<!-- Multiple malware downloads -->
<rule id="100051" level="12" frequency="3" timeframe="600">
    <if_matched_sid>100023</if_matched_sid>
    <same_source_ip />
    <description>HIGH: Multiple malware downloads from same source</description>
</rule>

